# orbit.yaml.edge — Edge deployment variant using local models
# Copy to orbit.yaml to use: cp orbit.yaml.edge orbit.yaml
system: orbit
version: 1

defaults:
  agent: opencode
  model: ollama/qwen2.5-coder
  timeout: 600
  max_turns: 10

settings:
  log_level: info
  workspace: .
  state_dir: .orbit

orbits:
  default_max: 20
  deadlock_threshold: 3
